<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFD949" >

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/homeLogo"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:src="@drawable/polaris_logo"
                android:adjustViewBounds="true"
                android:elevation="20dp"/>

            <TextView
                android:layout_width="302dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/shake"
                android:shadowColor="#55000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:text="Little Polaris"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="31sp"
                android:textStyle="bold" />

            <!-- LEARN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLearn"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_red"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📚"
                        android:textSize="48sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Learn"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="28sp"
                            android:fontFamily="@font/momina"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Numbers, ABCs And More →"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:fontFamily="@font/momina"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GAMES -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGames"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_blue"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎮"
                        android:textSize="48sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Games"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="28sp"
                            android:fontFamily="@font/momina"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Play And Earn Stars →"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:fontFamily="@font/momina"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- STARS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStars"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_green"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="48sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Stars"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="28sp"
                            android:fontFamily="@font/momina"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rewards And Badges →"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:fontFamily="@font/momina"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PARENTS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardParents"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginBottom="100dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_purple"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👨‍👩‍👧"
                        android:textSize="42sp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Parents Board"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="26sp"
                            android:fontFamily="@font/momina"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Track Progress →"
                            android:textColor="#000000"
                            android:textSize="16sp"
                            android:fontFamily="@font/momina"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <ImageButton
        android:id="@+id/btnAI"
        android:layout_width="85dp"
        android:layout_height="85dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="18dp"
        android:background="@drawable/ai_circle"
        android:elevation="20dp"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_star"/>

    <ImageButton
        android:id="@+id/btnCMR"
        android:layout_width="85dp"
        android:layout_height="85dp"
        android:layout_above="@id/btnAI"
        android:layout_alignEnd="@id/btnAI"
        android:background="@drawable/ai_circle"
        android:elevation="20dp"
        android:padding="12dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_cmr"/>

</RelativeLayout>